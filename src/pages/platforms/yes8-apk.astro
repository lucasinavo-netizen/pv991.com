<style>.container{max-width:980px;margin:0 auto;padding:2rem 1.25rem 3rem}.breadcrumb{font-size:.95rem;margin-bottom:1.5rem}.eyebrow{color:#ffc107;font-weight:800;text-transform:uppercase;font-size:.8rem;letter-spacing:0}.hero h1{font-size:clamp(2rem,4vw,3.1rem);margin:.25rem 0 .75rem}.hero p,.panel p,.panel li{line-height:1.85;opacity:.94}.cta-row{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1.1rem}.cta{display:inline-block;padding:.85rem 1.1rem;border-radius:10px;text-decoration:none;font-weight:800}.primary{background:linear-gradient(135deg,#ff3b5c,#ff6b00);color:#fff}.secondary{border:1px solid rgba(255,255,255,.15);color:#fff}.panel{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:1.1rem;margin-top:1.4rem}.score-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.85rem}.score-grid>div{background:rgba(0,0,0,.2);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:.9rem}.score-grid h3{margin:.1rem 0 .4rem}</style>