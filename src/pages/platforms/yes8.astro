---
import Layout from "../../layouts/Layout.astro";

const siteUrl = "https://www.pv991.com";

const platform = {
  slug: "yes8",
  name: "Yes8",
  url: "/go/p",
};

const title = "Yes8 Login, Slot & APK Guide Myanmar | PV991";
const description = "Yes8 Myanmar guide for players comparing login pages, slot games, APK safety, casino access, payment checks, and bonus rules before using any Yes8 link.";
const keywords = "yes8, yes8 slot, yes8 login, yes8 casino, yes8 apk, Yes8 Myanmar";

const ahrefsEvidence = [
  "Ahrefs Myanmar keyword ideas: yes8 ~3.0K, yes8 slot ~250, yes8 login ~200, yes8 casino ~100, yes8 apk ~100.",
  "Ahrefs SERP shows Google rewards official entrance, login/activity pages, social proof pages, and one Yes8 review page rather than generic casino articles.",
  "GSC shows PV991 has almost no Yes8 traffic yet, so this page should target the intent directly instead of relying on the homepage."
];
---

<Layout title={title} description={description} keywords={keywords}>
  <main class="container">
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/">ပင်မ</a> <span>›</span>
      <a href="/platforms/">ပလက်ဖောင်းများ</a> <span>›</span>
      <span>{platform.name}</span>
    </nav>

    <header class="hero">
      <p class="eyebrow">PV991 platform check</p>
      <h1>Yes8 Login, Slot နှင့် APK လမ်းညွှန်</h1>
      <p>
